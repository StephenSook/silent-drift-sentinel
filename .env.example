# Silent-Drift Sentinel: environment template. Copy to .env and fill in.
# Real secrets live in Doppler/Infisical, never in a committed file.

# ---- DataHub (self-hosted OSS on the cloud VM) ----
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=replace_with_service_account_pat
DATAHUB_FRONTEND_URL=http://localhost:9002

# ---- mcp-server-datahub (self-hosted sidecar) ----
MCP_SERVER_URL=http://localhost:8000/mcp
TOOLS_IS_MUTATION_ENABLED=true

# ---- LLM (agent reasoning only; kept out of the write path) ----
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Persistence ----
DATABASE_URL=postgresql://user:pass@host:5432/sentinel
REDIS_URL=rediss://default:pass@host:6379

# ---- Frontend / BFF ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENT_API_URL=http://localhost:8080

# ---- Observability (optional) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ---- Demo mode ----
SENTINEL_DEMO_MODE=false
